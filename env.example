# ─── Dreamland environment template ─────────────────────────────────────────
# Copy to .env (local) or set in Vercel / Railway / Supabase dashboard.
# Never commit real secrets.

# ─── PWA (Vercel) ───────────────────────────────────────────────────────────
DREAMLAND_API_URL=https://dreamland-t1ck.onrender.com/v1
DREAMLAND_UPLOADS_URL=https://dreamland-t1ck.onrender.com/frontend/web/uploads/image
DREAMLAND_PWA_URL=https://dreamland.app
DREAMLAND_ROOT_DOMAIN=dreamland.app

# ─── Yii2 API + Admin (Render) ───────────────────────────────────────────────
DREAMLAND_ADMIN_URL=https://dreamland-admin-450i.onrender.com
# Admin panel only — random 32+ char secret for Yii2 CSRF/session cookies
COOKIE_VALIDATION_KEY=generate-with-openssl-rand-hex-32

# ─── Supabase (PostgreSQL) ──────────────────────────────────────────────────
# Dashboard → Project Settings → Database
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_DB_HOST=db.YOUR_PROJECT_REF.supabase.co
SUPABASE_DB_PORT=5432
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=postgres
SUPABASE_DB_PASSWORD=your-db-password
# Pooler (recommended for serverless PHP): port 6543, user postgres.PROJECT_REF
DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres

# ─── Yii2 API (Railway / Render / Docker) ───────────────────────────────────
DB_DRIVER=pgsql
DB_HOST=${SUPABASE_DB_HOST}
DB_PORT=${SUPABASE_DB_PORT}
DB_NAME=${SUPABASE_DB_NAME}
DB_USER=${SUPABASE_DB_USER}
DB_PASSWORD=${SUPABASE_DB_PASSWORD}
YII_ENV=prod
YII_DEBUG=0
SITE_URL=https://your-api.example.com
DREAMLAND_DEV_MODE=0

# ─── Payments & AI ──────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_PUBLIC_KEY=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
FACEBOOK_OAUTH_CLIENT_ID=
FACEBOOK_OAUTH_CLIENT_SECRET=
GEMINI_API_KEY=
DREAMLAND_MOD_SECRET=change-me-in-production
DREAMLAND_LIVE_SECRET=change-me-in-production

# ─── Wasabi object storage (recommended for cPanel / shared hosting) ───────────
# Set DREAMLAND_STORAGE=wasabi so ALL uploads (photos, reels, covers) go to Wasabi.
DREAMLAND_STORAGE=wasabi
WASABI_ACCESS_KEY=your-wasabi-access-key
WASABI_SECRET_KEY=your-wasabi-secret-key
WASABI_REGION=us-east-1
WASABI_BUCKET=dreamland-media
WASABI_ENDPOINT=https://s3.us-east-1.wasabisys.com
# Optional: override public URL base (defaults to ENDPOINT/BUCKET)
DREAMLAND_WASABI_PUBLIC_URL=https://s3.us-east-1.wasabisys.com/dreamland-media
# PWA media base — set to Wasabi image folder after bucket is public
DREAMLAND_UPLOADS_URL=https://s3.us-east-1.wasabisys.com/dreamland-media/image

# ─── cPanel shared hosting (PWA on main domain) ───────────────────────────────
# Upload contents of web/ to public_html (main domain, e.g. https://dreamland.app).
# API + admin stay on subdomains:
#   api.yourdomain.com  → dreamland-api/api/web
#   admin.yourdomain.com → dreamland-admin/backend/web
# DREAMLAND_ROOT_DOMAIN=yourdomain.com
# DREAMLAND_PWA_URL=https://yourdomain.com
# DREAMLAND_API_URL=https://api.yourdomain.com/v1
# SITE_URL=https://api.yourdomain.com
# DREAMLAND_ADMIN_URL=https://admin.yourdomain.com

# ─── Optional services ──────────────────────────────────────────────────────
DREAMLAND_LIVE_SERVER_URL=
DREAMLAND_MODERATION_AGENT_URL=
SMTP_HOST=
SMTP_USER=
SMTP_PASSWORD=
