RewriteEngine On

# SPA fallback — serve index.html for client-side routes (Account, Wallet, etc.)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ index.html [L]

# Pass Authorization header to PHP on some shared hosts (if API is co-located)
RewriteCond %{HTTP:Authorization} ^(.*)
RewriteRule .* - [E=HTTP_AUTHORIZATION:%1]
