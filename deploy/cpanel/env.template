# Dreamland — dreamlandgh.app (cPanel / Namecheap)
# Copy to /home/USERNAME/dreamland/.env after upload (never commit real secrets).

YII_ENV=prod
YII_DEBUG=0
DREAMLAND_DEV_MODE=0

DREAMLAND_ROOT_DOMAIN=dreamlandgh.app
DREAMLAND_PWA_URL=https://dreamlandgh.app
SITE_URL=https://dreamlandgh.app
DREAMLAND_ADMIN_URL=https://dreamlandgh.app/admin
DREAMLAND_API_URL=https://dreamlandgh.app/api/v1

# Wasabi — all uploads (photos, reels, covers)
DREAMLAND_STORAGE=wasabi
WASABI_ACCESS_KEY=YOUR_WASABI_ACCESS_KEY
WASABI_SECRET_KEY=YOUR_WASABI_SECRET_KEY
WASABI_REGION=us-east-1
WASABI_BUCKET=dreamland-media
WASABI_ENDPOINT=https://s3.us-east-1.wasabisys.com
DREAMLAND_WASABI_PUBLIC_URL=https://s3.us-east-1.wasabisys.com/dreamland-media
DREAMLAND_UPLOADS_URL=https://s3.us-east-1.wasabisys.com/dreamland-media/image

# Admin session cookies — generate: php -r "echo bin2hex(random_bytes(32));"
COOKIE_VALIDATION_KEY=CHANGE_ME_64_CHAR_HEX

# Database — Supabase (recommended) OR cPanel MySQL (set DB_DRIVER=mysql)
DB_DRIVER=pgsql
DB_HOST=aws-0-REGION.pooler.supabase.com
DB_PORT=6543
DB_NAME=postgres
DB_USER=postgres.YOUR_PROJECT_REF
DB_PASSWORD=YOUR_SUPABASE_PASSWORD
