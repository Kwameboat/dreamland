# Dreamland — dreamlandgh.app (cPanel / Namecheap)
# Copy to /home/USERNAME/dreamland/.env after upload (never commit real secrets).

YII_ENV=prod
YII_DEBUG=0
DREAMLAND_DEV_MODE=0

DREAMLAND_ROOT_DOMAIN=dreamlandgh.app
DREAMLAND_PWA_URL=https://dreamlandgh.app
SITE_URL=https://dreamlandgh.app
DREAMLAND_ADMIN_URL=https://dreamlandgh.app/admin
DREAMLAND_API_URL=https://dreamlandgh.app/api/v1

# Storage — TRIAL: local cPanel disk. PRODUCTION: switch to wasabi (see bottom).
DREAMLAND_STORAGE=local
DREAMLAND_FORCE_LOCAL_UPLOADS=1
DREAMLAND_TRIAL_MODE=1
DREAMLAND_UPLOAD_DIR=/home/USERNAME/dreamland/api/runtime/uploads

# Wasabi — production only (comment out local flags above when enabling)
# DREAMLAND_STORAGE=wasabi
WASABI_ACCESS_KEY=YOUR_WASABI_ACCESS_KEY
WASABI_SECRET_KEY=YOUR_WASABI_SECRET_KEY
WASABI_REGION=us-east-1
WASABI_BUCKET=dreamland-media
WASABI_ENDPOINT=https://s3.us-east-1.wasabisys.com
DREAMLAND_WASABI_PUBLIC_URL=https://s3.us-east-1.wasabisys.com/dreamland-media
DREAMLAND_UPLOADS_URL=https://s3.us-east-1.wasabisys.com/dreamland-media/image

# Paystack (wallet top-up)
PAYSTACK_PUBLIC_KEY=
PAYSTACK_SECRET_KEY=

# Live WebRTC (required for creator go-live — deploy live-server/ on Railway/Render)
# DREAMLAND_LIVE_SERVER_URL=https://your-live.up.railway.app
# DREAMLAND_LIVE_SIGNALING_URL=https://your-live.up.railway.app
# DREAMLAND_LIVE_SECRET=change-me-in-production
# On live-server host also set: DREAMLAND_LIVE_CORS=https://dreamlandgh.app

# Admin session cookies — generate: php -r "echo bin2hex(random_bytes(32));"
COOKIE_VALIDATION_KEY=CHANGE_ME_64_CHAR_HEX

# Database — cPanel MySQL (required on Namecheap shared hosting; Supabase ports are blocked)
DB_DRIVER=mysql
DB_HOST=localhost
DB_PORT=3306
DB_NAME=dreaxdjo_dreamland
DB_USER=dreaxdjo_dluser
DB_PASSWORD=YOUR_CPANEL_MYSQL_PASSWORD
