{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "name": "dreamland-pwa",
  "buildCommand": "npm install --no-fund --no-audit && npm run build:web",
  "outputDirectory": "web",
  "framework": null,
  "rewrites": [
    { "source": "/js/(.*)", "destination": "/js/$1" },
    { "source": "/css/(.*)", "destination": "/css/$1" },
    { "source": "/assets/(.*)", "destination": "/assets/$1" },
    { "source": "/games/(.*)", "destination": "/games/$1" },
    { "source": "/manifest.json", "destination": "/manifest.json" },
    { "source": "/sw.js", "destination": "/sw.js" },
    { "source": "/env-config.js", "destination": "/env-config.js" },
    { "source": "/((?!.*\\.).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    },
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ]
}
